{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vestafolioco-api",
  "main": "src/index.js",
  "compatibility_date": "2026-06-01",
  "routes": [
    {
      "pattern": "vestafolioco.com/api/*",
      "zone_name": "vestafolioco.com"
    }
  ],
  "observability": {
    "enabled": true
  }
}
